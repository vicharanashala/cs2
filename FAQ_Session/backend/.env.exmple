NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://.....
# Google AI
GOOGLE_API_KEY=xyz

# Better Auth
BETTER_AUTH_SECRET=your_super_secret_key_min_32_chars
